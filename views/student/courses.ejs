<%- include('../partials/header') %>
<section>
  <div class="section-header">
    <h2>My Courses</h2>
  </div>
  <% if (courses.length === 0) { %>
    <p class="muted">You are not enrolled in any courses yet.</p>
  <% } %>
  <div class="grid">
    <% courses.forEach(course => { %>
      <a class="card link" href="/student/courses/<%= course.id %>">
        <h3><%= course.title %></h3>
        <p><%= course.code %> · <%= course.level %></p>
      </a>
    <% }) %>
  </div>
</section>
<%- include('../partials/footer') %>
