<%- include('../partials/header') %>
<section>
  <div class="section-header">
    <div>
      <h2><%= course.title %></h2>
      <p class="muted"><%= course.code %> À <%= course.level %></p>
    </div>
    <a class="button" href="/instructor/courses/<%= course.id %>/lessons/new">Add Lesson</a>
  </div>

  <% if (lessons.length === 0) { %>
    <p class="muted">No lessons yet. Add the first lesson for this course.</p>
  <% } else { %>
    <ul class="list">
      <% lessons.forEach(lesson => { %>
        <li>
          <strong><%= lesson.order_index %>. <%= lesson.title %></strong>
          <p><%= lesson.content %></p>
        </li>
      <% }) %>
    </ul>
  <% } %>
</section>
<%- include('../partials/footer') %>
